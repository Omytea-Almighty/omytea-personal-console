# ---------------------------------------------------------------------
# Omytea Console — native sign-in (st.login / st.user), Google OIDC.
#
# This is a TEMPLATE. The real file, .streamlit/secrets.toml, is
# gitignored (never commit client secrets). Two ways to apply it:
#
#   * Local dev — copy this file to .streamlit/secrets.toml and fill in
#     real values.
#   * Streamlit Cloud — paste the [auth] block (with real values) into
#     Manage app -> Settings -> Secrets. No file needed on the server.
#
# Until [auth] is configured the console runs fine: the sidebar account
# area simply shows a "sign-in not set up yet" hint instead of logging
# anyone in.
#
# ---- One-time Google setup --------------------------------------------
#  1. https://console.cloud.google.com -> APIs & Services -> Credentials
#  2. "Create credentials" -> "OAuth client ID" -> type "Web application"
#  3. Authorized redirect URIs — add BOTH:
#       https://omytea-personal-console.streamlit.app/oauth2callback
#       http://localhost:8501/oauth2callback
#  4. Copy the generated Client ID and Client secret into this file.
#  5. cookie_secret — any long random string. Generate one with:
#       python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------

[auth]
redirect_uri = "https://omytea-personal-console.streamlit.app/oauth2callback"
cookie_secret = "REPLACE_WITH_A_LONG_RANDOM_STRING"
client_id = "REPLACE_WITH_GOOGLE_CLIENT_ID"
client_secret = "REPLACE_WITH_GOOGLE_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ---- Durable storage (Turso libSQL) — iter #44 ------------------------
# Without this block the console writes predictions to a LOCAL SQLite at
# ~/.omytea-personal-console/predictions.db . On Streamlit Cloud that
# path is ephemeral — every redeploy wipes the DB, so the calibration
# loop "predict → wait N months → score" CANNOT survive a reboot.
#
# Wire Turso (3-min setup, see SETUP_TURSO.md):
#   1. Install + auth:    brew install tursodatabase/tap/turso
#                         turso auth login
#   2. Create the DB:     turso db create omytea-personal-console --location lhr
#   3. Get URL:           turso db show omytea-personal-console --url
#   4. Get auth token:    turso db tokens create omytea-personal-console
#   5. Paste below + Save in Streamlit Cloud Secrets.
#
# Free tier: 9 GB / 500 dbs / 1B row-reads + 25M row-writes per month —
# comfortably oversized for calibration-research scope.
# ---------------------------------------------------------------------

[turso]
url = "libsql://REPLACE_WITH_YOUR_TURSO_DB_URL.turso.io"
auth_token = "REPLACE_WITH_YOUR_TURSO_AUTH_TOKEN"
